#!/usr/bin/env bash
set -euo pipefail

repository="Hsiii/Homepage"
workflow="image.yml"
host="${PLATFORM_HOST:-platform}"
remote_deploy_script="${PLATFORM_HOMEPAGE_DEPLOY_SCRIPT:-/srv/platform/operations/scripts/deploy-homepage}"

branch="$(git branch --show-current)"

if [[ "$branch" != "main" ]]; then
    echo "Deploy from main. Current branch is ${branch:-\(detached\)}." >&2
    exit 1
fi

if [[ -n "$(git status --porcelain)" ]]; then
    echo "Commit or stash local changes before deploying." >&2
    exit 1
fi

commit="$(git rev-parse HEAD)"
remote_commit="$(git ls-remote --exit-code origin refs/heads/main | awk '{print $1}')"

if [[ "$commit" != "$remote_commit" ]]; then
    echo "Local main does not match origin/main. Merge changes through a PR, then update local main before deploying. This script never pushes code." >&2
    exit 1
fi

run_id=""
for _ in {1..30}; do
    run_id="$(gh run list \
        --repo "$repository" \
        --workflow "$workflow" \
        --commit "$commit" \
        --limit 1 \
        --json databaseId \
        --jq '.[0].databaseId // empty')"
    [[ -n "$run_id" ]] && break
    sleep 2
done

if [[ -z "$run_id" ]]; then
    echo "No $workflow run appeared for $commit." >&2
    exit 1
fi

gh run watch "$run_id" --repo "$repository" --exit-status
ssh "$host" "$remote_deploy_script"
